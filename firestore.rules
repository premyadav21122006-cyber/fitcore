rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Collection Rules ---

    // Members (Login Support)
    match /members/{memberId} {
      function isValidMember(data) {
        return data.keys().hasAll(['username', 'password', 'name', 'membershipType', 'joinDate', 'expiryDate', 'status']) &&
               data.username is string && data.username.size() <= 64 &&
               data.password is string && data.password.size() <= 64 &&
               data.name is string && data.name.size() <= 128;
      }

      allow read, list: if true;
      allow create, update: if isValidMember(incoming());
      allow delete: if true;
    }

    // Attendance
    match /attendance/{attendanceId} {
      allow read, list: if true;
      allow create: if true;
    }

    // Payments
    match /payments/{paymentId} {
      allow read, list: if true;
      allow create, update: if true;
    }

    // Workout Plans
    match /workout_plans/{planId} {
      allow read, list: if true;
      allow create, update, delete: if true;
    }

    // Diet Plans
    match /diet_plans/{planId} {
      allow read, list: if true;
      allow create, update, delete: if true;
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read, list: if true;
      allow create, update: if true;
    }

    // Users
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
